# Server
PORT=3100

# Default AI keys (can be overridden via /settings UI → stored in SQLite)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Email — QQ SMTP
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_qq@qq.com
SMTP_PASS=your_qq_auth_code
MAIL_TO=recipient@example.com

# Timezone
TZ=Asia/Hong_Kong
